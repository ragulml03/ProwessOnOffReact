# LaunchDarkly
VITE_LD_CLIENT_SIDE_ID=your-ld-client-side-id

# AWS Pinpoint analytics
# Get VITE_PINPOINT_APP_ID from: AWS Console → Pinpoint → your project → App ID
# Get VITE_COGNITO_IDENTITY_POOL_ID from: AWS Console → Cognito → Identity Pools → your pool
VITE_PINPOINT_APP_ID=your-pinpoint-app-id
VITE_COGNITO_IDENTITY_POOL_ID=eu-north-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
VITE_AWS_REGION=eu-north-1
